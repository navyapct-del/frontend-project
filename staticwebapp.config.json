{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/favicon.ico", "/*.{css,js,png,jpg,svg,webp,ttf,woff,woff2}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  },
  "routes": [
    {
      "route": "/keycloak/*",
      "rewrite": "http://dataocd-keycloak.eastus.azurecontainer.io:8080/*"
    }
  ]
}
